#!/usr/bin/env bash
# git-clone — clone a GitHub repo locally with the contributor-style
# two-remote layout, when the fork already exists on GitHub.
#
# Usage:
#   git-clone <repo> [account] [directory]
#
#   <repo>      A GitHub repository as "owner/name", or a GitHub HTTPS / SSH URL.
#               This is the upstream repository.
#   [account]   The GitHub user or organization that owns the existing fork.
#               Defaults to the currently authenticated `gh` user. Pass "" to
#               use the default while still specifying [directory].
#   [directory] Local directory to clone into. Defaults to the repo name.
#
# Result:
#   ./<directory>/  cloned from <repo> with two remotes:
#                     upstream → original repo (local default branch tracks it)
#                     fork     → github.com/<account>/<name>
#
# Unlike `git-fork`, this script does not create a fork on GitHub and does
# not apply repo settings — the fork is assumed to already exist.
#
# Requires: git, gh (https://cli.github.com), authenticated.

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: git-clone <repo> [account] [directory]

  <repo>      "owner/name", or a GitHub https/ssh URL. The upstream repo.
  [account]   Owner of the existing fork. Defaults to the authenticated gh
              user. Pass "" to use the default while still specifying
              [directory].
  [directory] Local directory to clone into. Defaults to the repo name.

Clones <repo> into ./<directory> with two remotes:
  upstream → original repo (local default branch tracks upstream)
  fork     → github.com/<account>/<name>

The fork must already exist on GitHub. This script does not create a
fork or apply repo settings — use `git-fork` for that.
EOF
  exit 2
}

case "${1:-}" in -h|--help) usage ;; esac
(( $# >= 1 && $# <= 3 )) || usage

repo_arg="$1"
account="${2:-}"
target_dir="${3:-}"

command -v git >/dev/null 2>&1 || { echo "git-clone: 'git' is required" >&2; exit 1; }
command -v gh  >/dev/null 2>&1 || { echo "git-clone: 'gh' (GitHub CLI) is required" >&2; exit 1; }

# Normalise the repo argument to "owner/name".
slug="${repo_arg%.git}"
case "$slug" in
  git@github.com:*)        slug="${slug#git@github.com:}" ;;
  ssh://git@github.com/*)  slug="${slug#ssh://git@github.com/}" ;;
  https://github.com/*)    slug="${slug#https://github.com/}" ;;
  http://github.com/*)     slug="${slug#http://github.com/}" ;;
esac
slug="${slug%/}"
if [[ "$slug" != */* || "$slug" == */*/* ]]; then
  echo "git-clone: cannot parse '$repo_arg' as <owner>/<name>" >&2
  exit 1
fi
upstream_owner="${slug%%/*}"
repo_name="${slug#*/}"

if [[ -z "$account" ]]; then
  account="$(gh api user --jq .login)"
fi

if [[ "$account" == "$upstream_owner" ]]; then
  echo "git-clone: fork account '$account' is the upstream owner; there is no fork to wire up" >&2
  echo "           (use 'git clone' directly, or 'git-fork' if you meant to create a fork)" >&2
  exit 1
fi

if [[ -z "$target_dir" ]]; then
  target_dir="$repo_name"
fi

if [[ -e "$target_dir" ]]; then
  echo "git-clone: ./$target_dir already exists; refusing to overwrite" >&2
  exit 1
fi

echo "==> Verifying fork ${account}/${repo_name} exists"
if ! gh repo view "${account}/${repo_name}" --json name >/dev/null 2>&1; then
  echo "git-clone: fork ${account}/${repo_name} not found on GitHub" >&2
  echo "           (use 'git-fork' to create it, or pass the correct [account])" >&2
  exit 1
fi

upstream_url="https://github.com/${upstream_owner}/${repo_name}.git"
fork_url="https://github.com/${account}/${repo_name}.git"

echo "==> Cloning ${upstream_owner}/${repo_name} into ./${target_dir} (remote: upstream)"
git clone -o upstream "$upstream_url" "$target_dir"

echo "==> Adding fork remote → ${fork_url}"
git -C "$target_dir" remote add fork "$fork_url"

echo "==> Done."
git -C "$target_dir" remote -v
