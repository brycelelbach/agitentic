#!/usr/bin/env bash
# git-create — create a new GitHub repo, clone it locally, make an
# empty initial commit on `main`, and apply repo settings.
#
# Usage:
#   git-create <name> [account] [directory]
#
#   <name>      Repository name (just the name, no owner).
#   [account]   GitHub user or organization to create the repo in.
#               Defaults to the authenticated `gh` user. Pass "" to use
#               the default while still specifying [directory].
#   [directory] Local directory to initialise. Defaults to the repo name.
#
# The new repo is created with `gh repo create --public`.
#
# Repo settings (applied via `gh repo edit`) default to:
#   delete-branch-on-merge=true
#   enable-wiki=false
#   enable-projects=false
#   enable-merge-commit=false
#   enable-squash-merge=false
# Override per-key from a `[repo]` section in ~/.agitentic (git config
# format), or set $AGITENTIC_CONFIG to use a different file. Built-in
# defaults still apply for keys not in the file.
#
# Security settings, each default true, overridable via [security] in the
# same config file:
#   dependabot-alerts             — PUT /repos/{owner}/{repo}/vulnerability-alerts
#   dependabot-security-updates   — PUT /repos/{owner}/{repo}/automated-security-fixes
#   codeql-default-setup          — PATCH /repos/{owner}/{repo}/code-scanning/default-setup
# Failures here are warned-about but non-fatal (e.g. CodeQL default setup
# needs at least one supported language, so it fails on an empty repo).
#
# Result:
#   ./<directory>/  newly-initialised repo with one empty commit on
#                   `main`, with `origin` pointing at github.com/
#                   <account>/<name>.
#
# Requires: git, gh (https://cli.github.com), authenticated.

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: git-create <name> [account] [directory]

  <name>      Repository name (just the name, no owner).
  [account]   GitHub user or organization. Defaults to the authenticated
              gh user. Pass "" to use the default while still specifying
              [directory].
  [directory] Local directory. Defaults to the repo name.

Creates github.com/<account>/<name> (public), initialises ./<directory>,
makes an empty initial commit on `main`, and pushes.

Applies repo settings via `gh repo edit`. Defaults are listed in the
script header; override per-key in the [repo] section of ~/.agitentic
(or $AGITENTIC_CONFIG) using git config format.
EOF
  exit 2
}

# shellcheck source=../../../lib/repo-settings.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../../lib/repo-settings.sh"

# Enable dependabot alerts, automated security fixes, and CodeQL default
# scanning. Each step can be toggled off via [security] in ~/.agitentic
# (e.g. `security.codeql-default-setup = false`). Failures are warned
# about but non-fatal — the main repo is already created by this point.
apply_security_settings() {
  local repo_slug="$1"
  local -A settings=(
    [dependabot-alerts]=true
    [dependabot-security-updates]=true
    [codeql-default-setup]=true
  )

  local config_file="${AGITENTIC_CONFIG:-$HOME/.agitentic}"
  if [[ -f "$config_file" ]]; then
    local key value
    while IFS='=' read -r key value; do
      case "$key" in
        security.*) settings["${key#security.}"]="$value" ;;
      esac
    done < <(git config -f "$config_file" --list)
  fi

  echo "==> Applying security settings to ${repo_slug}"

  if [[ "${settings[dependabot-alerts]}" == "true" ]]; then
    echo "  enabling dependabot alerts"
    gh api --silent --method PUT "/repos/${repo_slug}/vulnerability-alerts" \
      || echo "  (warning: dependabot alerts not enabled)"
  fi

  if [[ "${settings[dependabot-security-updates]}" == "true" ]]; then
    echo "  enabling dependabot security updates"
    gh api --silent --method PUT "/repos/${repo_slug}/automated-security-fixes" \
      || echo "  (warning: dependabot security updates not enabled)"
  fi

  if [[ "${settings[codeql-default-setup]}" == "true" ]]; then
    echo "  enabling CodeQL default setup"
    gh api --silent --method PATCH "/repos/${repo_slug}/code-scanning/default-setup" \
      -f state=configured \
      || echo "  (warning: CodeQL default setup not enabled — repo may have no supported languages yet)"
  fi
}

case "${1:-}" in -h|--help) usage ;; esac
(( $# >= 1 && $# <= 3 )) || usage

name_arg="$1"
account="${2:-}"
target_dir="${3:-}"

if [[ -z "$name_arg" ]]; then
  echo "git-create: <name> is required" >&2
  exit 2
fi
if [[ "$name_arg" == */* ]]; then
  echo "git-create: <name> must be just the repo name, not 'owner/name'" >&2
  echo "            (use [account] for the owner)" >&2
  exit 1
fi

command -v git >/dev/null 2>&1 || { echo "git-create: 'git' is required" >&2; exit 1; }
command -v gh  >/dev/null 2>&1 || { echo "git-create: 'gh' (GitHub CLI) is required" >&2; exit 1; }

if [[ -z "$account" ]]; then
  account="$(gh api user --jq .login)"
fi

if [[ -z "$target_dir" ]]; then
  target_dir="$name_arg"
fi

if [[ -e "$target_dir" ]]; then
  echo "git-create: ./$target_dir already exists; refusing to overwrite" >&2
  exit 1
fi

repo_slug="${account}/${name_arg}"
repo_url="https://github.com/${repo_slug}.git"

echo "==> Creating ${repo_slug} on GitHub (public)"
gh repo create "$repo_slug" --public >/dev/null

echo "==> Initialising ./${target_dir}"
git init -q -b main "$target_dir"
git -C "$target_dir" remote add origin "$repo_url"
git -C "$target_dir" commit -q --allow-empty -m "Initial commit"

echo "==> Pushing initial commit"
git -C "$target_dir" push -q -u origin main

agitentic_apply_repo_settings "$repo_slug"
apply_security_settings "$repo_slug"

echo "==> Done."
git -C "$target_dir" remote -v
