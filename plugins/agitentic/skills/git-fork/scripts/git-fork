#!/usr/bin/env bash
# git-fork — fork a GitHub repo, clone the upstream locally, configure
# `upstream` and `fork` remotes, and apply repo settings to the repo.
#
# Usage:
#   git-fork <repo> [name] [account] [directory]
#
#   <repo>      A GitHub repository as "owner/name", or a GitHub HTTPS / SSH URL.
#   [name]      Name to use for the fork on GitHub (and the default local
#               directory). Defaults to the upstream repo name. Pass "" to use
#               the default while still specifying [account] or [directory].
#   [account]   The GitHub user or organization to fork into. Defaults to the
#               currently authenticated `gh` user. Pass "" to use the default
#               while still specifying [directory].
#   [directory] Local directory to clone into. Defaults to [name] (which itself
#               defaults to the upstream repo name).
#
# Fork repo settings (applied via `gh repo edit`) default to:
#   delete-branch-on-merge=true
#   enable-wiki=false
#   enable-projects=false
#   enable-merge-commit=false
#   enable-squash-merge=false
#   enable-auto-merge=true
#   allow-update-branch=true
# Override per-key from a `[repo]` section in ~/.agitentic (git config
# format), or set $AGITENTIC_CONFIG to use a different file.
#
# Security settings, each default true, overridable via [security] in the
# same config file:
#   dependabot-alerts             — PUT /repos/{owner}/{repo}/vulnerability-alerts
#   dependabot-security-updates   — PUT /repos/{owner}/{repo}/automated-security-fixes
#   codeql-default-setup          — PATCH /repos/{owner}/{repo}/code-scanning/default-setup
# Failures here are warned-about but non-fatal (e.g. CodeQL default setup
# needs at least one supported language, so it fails on an empty repo).
#
# Result:
#   ./<directory>/  cloned from <repo> with two remotes:
#                     upstream → original repo (local default branch tracks it)
#                     fork     → github.com/<account>/<name>
#
# Requires: git, gh (https://cli.github.com), authenticated.

set -euo pipefail

usage() {
  cat >&2 <<'EOF'
Usage: git-fork <repo> [name] [account] [directory]

  <repo>      "owner/name", or a GitHub https/ssh URL.
  [name]      Name to use for the fork. Defaults to the upstream repo name.
              Pass "" to use the default while still specifying [account] or
              [directory].
  [account]   Destination owner for the repo. Defaults to the authenticated
              gh user. Pass "" to use the default while still specifying
              [directory].
  [directory] Local directory to clone into. Defaults to [name].

Clones <repo> into ./<directory> with two remotes:
  upstream → original repo (local default branch tracks upstream)
  fork     → github.com/<account>/<name>

Applies fork repo settings via `gh repo edit`. Defaults are listed in
the script header; override per-key in the [repo] section of
~/.agitentic (or $AGITENTIC_CONFIG) using git config format.
EOF
  exit 2
}

# shellcheck source=../../../lib/repo-settings.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../../lib/repo-settings.sh"
# shellcheck source=../../../lib/security-settings.sh
source "$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)/../../../lib/security-settings.sh"

case "${1:-}" in -h|--help) usage ;; esac
(( $# >= 1 && $# <= 4 )) || usage

repo_arg="$1"
fork_name="${2:-}"
account="${3:-}"
target_dir="${4:-}"

command -v git >/dev/null 2>&1 || { echo "git-fork: 'git' is required" >&2; exit 1; }
command -v gh  >/dev/null 2>&1 || { echo "git-fork: 'gh' (GitHub CLI) is required" >&2; exit 1; }

# Normalise the repo argument to "owner/name".
slug="${repo_arg%.git}"
case "$slug" in
  git@github.com:*)        slug="${slug#git@github.com:}" ;;
  ssh://git@github.com/*)  slug="${slug#ssh://git@github.com/}" ;;
  https://github.com/*)    slug="${slug#https://github.com/}" ;;
  http://github.com/*)     slug="${slug#http://github.com/}" ;;
esac
slug="${slug%/}"
if [[ "$slug" != */* || "$slug" == */*/* ]]; then
  echo "git-fork: cannot parse '$repo_arg' as <owner>/<name>" >&2
  exit 1
fi
upstream_owner="${slug%%/*}"
upstream_name="${slug#*/}"

if [[ -z "$fork_name" ]]; then
  fork_name="$upstream_name"
fi

if [[ -z "$account" ]]; then
  account="$(gh api user --jq .login)"
fi

if [[ -z "$target_dir" ]]; then
  target_dir="$fork_name"
fi

if [[ -e "$target_dir" ]]; then
  echo "git-fork: ./$target_dir already exists; refusing to overwrite" >&2
  exit 1
fi

upstream_url="https://github.com/${upstream_owner}/${upstream_name}.git"
fork_url="https://github.com/${account}/${fork_name}.git"

echo "==> Cloning ${upstream_owner}/${upstream_name} into ./${target_dir} (remote: upstream)"
git clone -o upstream "$upstream_url" "$target_dir"

if [[ "$account" == "$upstream_owner" && "$fork_name" == "$upstream_name" ]]; then
  echo "==> Skipping fork: ${account}/${fork_name} is the upstream"
else
  echo "==> Forking ${upstream_owner}/${upstream_name} → ${account}/${fork_name}"
  authed_user="$(gh api user --jq .login)"
  fork_args=("${upstream_owner}/${upstream_name}" --clone=false)
  if [[ "$account" != "$authed_user" ]]; then
    fork_args+=(--org "$account")
  fi
  if [[ "$fork_name" != "$upstream_name" ]]; then
    fork_args+=(--fork-name "$fork_name")
  fi
  gh repo fork "${fork_args[@]}" >/dev/null
  agitentic_apply_repo_settings "${account}/${fork_name}"
  agitentic_apply_security_settings "${account}/${fork_name}"
fi

echo "==> Adding fork remote → ${fork_url}"
git -C "$target_dir" remote add fork "$fork_url"

echo "==> Done."
git -C "$target_dir" remote -v
